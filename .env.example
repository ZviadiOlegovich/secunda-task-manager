# Server
SERVER_PORT=8080
SERVER_PRIVATE_PORT=8081
SERVER_SERVICE_NAME=secunda-task-manager
SERVER_LOG_LEVEL=info
SERVER_LOG_FORCE_PLAIN_TEXT=false

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=taskuser
MYSQL_PASSWORD=taskpassword
MYSQL_DBNAME=taskmanager
MYSQL_MAX_OPEN_CONNS=25
MYSQL_MAX_IDLE_CONNS=5
MYSQL_CONN_MAX_LIFETIME=5m
MYSQL_CONN_MAX_IDLE_TIME=1m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# JWT
TOKEN_ISSUER=secunda-task-manager
LEEWAY=5s
ACCESS_TOKEN_KEY=change_me_access_key
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_KEY=change_me_refresh_key
REFRESH_TOKEN_TTL=168h

# App
APP_ALLOWED_ORIGINS=http://localhost:3000
